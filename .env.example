# =============================================================================
# Open Hearth Budget — Environment variables
# Copy to .env in the repo root
# =============================================================================

# ----- PostgreSQL ------------------------------------------------------------
POSTGRES_DB=household_budget
POSTGRES_PORT=5432

# Without Docker (macOS): run  npm run db:setup-local
DATABASE_URL=postgres://YOUR_USER@localhost:5432/household_budget

# With Docker Compose:
# POSTGRES_USER=app
# DB_PASSWORD=change-me-in-production
# DATABASE_URL=postgres://app:change-me-in-production@localhost:5432/household_budget

# Generate: openssl rand -base64 32
AUTH_SECRET=dev-secret-change-me-min-16-chars

# ----- API -------------------------------------------------------------------
API_PORT=3000
API_URL=http://localhost:3000
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
SESSION_DAYS=30
COOKIE_SECURE=false
SEED_DEMO_USER=true
NODE_ENV=development

# SMTP (optional — Mailpit with docker compose --profile dev)
SMTP_HOST=localhost
SMTP_PORT=1025

# Optional invite token secret (defaults to AUTH_SECRET)
# INVITE_JWT_SECRET=
# INVITE_JWT_EXPIRES_IN=7d

# ----- Frontend (Vite — prefix VITE_) ----------------------------------------
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=Open Hearth Budget
VITE_APP_URL=http://localhost:5173
VITE_DEFAULT_LOCALE=en
VITE_DEFAULT_CURRENCY=USD
VITE_DEFAULT_TIMEZONE=America/El_Salvador
