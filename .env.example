# =============================================================================
# Household Budget - Environment variables example
# Copy to .env.local and fill in the values for local development.
# =============================================================================

# ----- Supabase (REQUIRED) ---------------------------------------------------
# Create a project at https://app.supabase.com
# Copy values from: Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ----- App (optional) --------------------------------------------------------
VITE_APP_NAME=PresupuestoHogar
VITE_APP_URL=http://localhost:5173
VITE_DEFAULT_LOCALE=es
VITE_DEFAULT_CURRENCY=COP
VITE_DEFAULT_TIMEZONE=America/El_Salvador

# =============================================================================
# Server-side only (Netlify Functions) - DO NOT prefix with VITE_
# These are NEVER exposed to the browser.
# =============================================================================

# ----- Supabase service role (REQUIRED for functions) -----------------------
# This bypasses RLS - keep it SECRET.
# Project Settings -> API -> service_role secret
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET

# ----- Resend (REQUIRED for emails + Supabase Auth SMTP) --------------------
# Sign up at https://resend.com - free 3,000 emails/month.
# Verify your domain or use onboarding@resend.dev for development.
RESEND_API_KEY=re_YOUR_RESEND_KEY
RESEND_FROM_EMAIL=PresupuestoHogar <no-reply@yourdomain.com>

# ----- App URL for email links (REQUIRED) -----------------------------------
# Used by Netlify Functions when building invite URLs etc.
APP_URL=http://localhost:5173

# ----- Invitations: JWT signing secret (REQUIRED) ---------------------------
# Generate with: openssl rand -base64 48
INVITE_JWT_SECRET=replace-me-with-a-strong-random-secret
INVITE_JWT_EXPIRES_IN=7d
